# --- Application Configuration ---
# Port number on which the main application service runs locally
APP_PORT=8090
# Base URL host address for the application
APP_HOST=http://localhost
# Docker image tag/name used for local containerized deployment of the main app
APP_IMAGE_NAME=mail_and_media_shop_v2:app
# Container name assigned to the running application in Docker Compose
APP_CONTAINER_NAME=mail_and_media_shop_v2
# Base name of the application image used in CI/CD build steps
IMAGE_NAME=

# --- Shop Database (PostgreSQL) ---
# Version tag of the official PostgreSQL Docker image
POSTGRES_IMAGE_VERSION=16
# Container name for the shop database instance
SHOP_DB_CONTAINER_NAME=shop_db
# Database name for the shop's application schema
SHOP_DB_NAME=shop_db
# Username credential for PostgreSQL shop database connection
SHOP_DB_USER=
# Password credential for PostgreSQL shop database connection
SHOP_DB_PASSWORD=
# Host port mapped to PostgreSQL shop database container
SHOP_DB_PORT=5430

# --- Redis Configuration ---
# Port number for Redis cache and message broker connection
REDIS_PORT=6379

# --- Keycloak Configuration ---
# HTTP port mapped to Keycloak identity provider service
KEYCLOAK_PORT=8080
# HTTPS port mapped to Keycloak identity provider service
KEYCLOAK_HTTPS_PORT=8443
# Full HTTPS endpoint URL for Keycloak authentication services
KC_URL=https://localhost:8443
# Name of the Keycloak realm containing user and client settings
KC_REALM=mail-and-media-shop-realm
# Username for initializing Keycloak bootstrap admin account
KC_BOOTSTRAP_ADMIN_USERNAME=admin
# Password for initializing Keycloak bootstrap admin account
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
# Username for executing administrative tasks via Keycloak API
KC_ADMIN_USER=admin
# Password for executing administrative tasks via Keycloak API
KC_ADMIN_PASS=admin

# --- Keycloak Client Configuration ---
# OAuth2 client identifier for the main application
KC_CLIENT_ID=
# OAuth2 client secret credential for the application client
KC_CLIENT_SECRET=
# OAuth2 grant type used to authenticate client users (e.g., password, client_credentials)
KC_GRANT_TYPE=
# Username of the test client user configured in Keycloak
KC_USERNAME=
# Password of the test client user configured in Keycloak
KC_PASSWORD=

# --- Keycloak Database (PostgreSQL) ---
# Docker image version for Keycloak's dedicated PostgreSQL database
KEYCLOAK_DB_IMAGE_VERSION=15-alpine
# Container name for Keycloak database instance
KEYCLOAK_DB_CONTAINER_NAME=
# Database schema name for Keycloak authentication data
KEYCLOAK_DB_NAME=
# Username credential for Keycloak database connection
KEYCLOAK_DB_USER=
# Password credential for Keycloak database connection
KEYCLOAK_DB_PASSWORD=
# Port mapped to Keycloak database container
KEYCLOAK_DB_PORT=5435

# --- SonarQube Configuration ---
# Docker image version for SonarQube analysis server
SONAR_IMAGE_VERSION=
# Container name for SonarQube analysis server instance
SONAR_CONTAINER_NAME=
# Port number mapped to SonarQube dashboard interface
SONAR_PORT=9000
# Full URL endpoint where SonarQube server is reachable in the docker network
SONAR_HOST_URL=http://sonarqube:9000
# Authentication token for publishing project reports to SonarQube
SONAR_TOKEN=

# --- SonarQube Database ---
# Docker image version for SonarQube PostgreSQL database
SONAR_DB_IMAGE_VERSION=16
# Container name for SonarQube database instance
SONAR_DB_CONTAINER_NAME=sonarqube_db
# Database name for storing SonarQube analytics data
SONAR_DB_NAME=sonar
# Username credential for SonarQube database connection
SONAR_DB_USER=sonar
# Password credential for SonarQube database connection
SONAR_DB_PASSWORD=sonar

# --- Security & JWT ---
# Identifier of the authority that issues JWT access tokens
JWT_ISSUER=auth-service
# Expiration duration of generated JWT access tokens in milliseconds
JWT_EXPIRATION_MS=86400000
# Expected recipient (audience) identifier validated on JWT claims
JWT_EXPECTED_AUDIENCE=mail-and-media-shop-app

# --- Social Login (Google) ---
# Client ID credential for Google OAuth2 integration
GOOGLE_CLIENT_ID=
# Client secret credential for Google OAuth2 integration
GOOGLE_CLIENT_SECRET=

# --- Frontend Configuration ---
# Base URL location where frontend web application is hosted
APPLICATION_FRONTEND_URL=http://localhost:3000

# --- Other Integrations ---
# Endpoint URL for external service integration
PRODUCER_URL=http://localhost:8097

# --- Monitoring ---
# Username for Grafana administration login
GRAFANA_ADMIN_USER=
# Password for Grafana administration login
GRAFANA_ADMIN_PASSWORD=
# Host port mapped to Grafana visualization dashboard
GRAFANA_PORT=3000
# Host port mapped to Prometheus metrics aggregator dashboard
PROMETHEUS_PORT=9090
# Host port mapped to Loki log collection dashboard
LOKI_PORT=3100
# Host port mapped to Alloy telemetry agent dashboard
ALLOY_PORT=12345

# --- Exporters ---
# Port mapped to PostgreSQL metrics exporter for the main shop database
POSTGRES_EXPORTER_SHOP_PORT=9187
# Port mapped to PostgreSQL metrics exporter for Keycloak database
POSTGRES_EXPORTER_KEYCLOAK_PORT=9188
# Port mapped to Redis metrics exporter instance
REDIS_EXPORTER_PORT=9121

# --- ELK Stack Configuration ---
# Docker image version for Elasticsearch search engine
ELASTICSEARCH_IMAGE_VERSION=9.4.2
# Host port mapped to Elasticsearch HTTP server REST API
ELASTICSEARCH_PORT=9200
# Host port mapped to Elasticsearch internal node communication channel
ELASTICSEARCH_PORT_TRANS=9300
# Internal Docker network URL endpoint for Elasticsearch
ELASTIC_INTERNAL_URL=http://elasticsearch:9200
# Hosts list formatted as JSON array for Elasticsearch cluster routing
ELASTICSEARCH_HOSTS=["http://elasticsearch:9200"]
# Docker image version for Kibana administration UI
KIBANA_IMAGE_VERSION=9.4.2
# Host port mapped to Kibana data visualization dashboard
KIBANA_PORT=5601
# Docker image version for Logstash logging engine
LOGSTASH_IMAGE_VERSION=9.4.2
# Port number mapped to Logstash server interface
LOGSTASH_PORT=9600

# --- Test User Credentials ---
# Name for testing dummy user profiles
USER_NAME=
# Email address credential for testing dummy user profiles
USER_EMAIL=
# Password credential for testing dummy user profiles
USER_PASSWORD=

# --- SSH ---
# Target remote server login user credential for deployment processes
SSH_USER=
# Target remote server hostname or IP address for deployment processes
SSH_HOST=